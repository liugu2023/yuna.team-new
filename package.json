{
  "name": "yuna-team-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --d1 BLOG_DB --r2 BLOG_BUCKET --compatibility-date=2026-06-19",
    "deploy": "wrangler pages deploy public",
    "db:migrate:local": "wrangler d1 migrations apply BLOG_DB --local",
    "db:migrate": "wrangler d1 migrations apply BLOG_DB --remote",
    "media:migrate": "node scripts/migrate-media.mjs",
    "content:check": "node scripts/check-content.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260618.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.5"
  }
}
